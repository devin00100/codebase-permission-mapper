{
  "name": "codebase-permission-mapper",
  "version": "1.3.0",
  "description": "Analyse the Source code, database structure and mapping the permissions, supports Js/Ts",
  "main": "electron-main.js",
  "scripts": {
    "scan": "node scanner/index.js",
    "map": "node context-engine/index.js",
    "full": "npm run scan && npm run map",
    "dev": "cd visualizer && npm run dev",
    "build": "cd visualizer && npm run build",
    "electron:dev": "npm run build && electron .",
    "electron:start": "electron .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:portable": "npm run build && electron-builder --win portable",
    "setup": "npm install && cd visualizer && npm install"
  },
  "keywords": [
    "permissions",
    "security",
    "api",
    "scanner",
    "audit",
    "authorization",
    "electron",
    "desktop"
  ],
  "author": "Deepak Ashok Karai",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.dudemac.mapper",
    "productName": "Permission Mapper",
    "copyright": "Copyright 2024",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron-main.js",
      "preload.js",
      "scanner/**/*",
      "context-engine/**/*",
      "mapper.config.json",
      "invserver.config.json",
      "visualizer/dist/**/*",
      "package.json",
      "node_modules/sql.js/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist",
        "to": "sql.js",
        "filter": ["sql-wasm.wasm"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}.${ext}"
    },
    "asar": true
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  }
}
